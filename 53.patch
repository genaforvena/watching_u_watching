+
+num_rounds = 4 # @param {type:"integer"}
+
+import sys
+import os
+
+# Add the project root to sys.path to resolve imports
+script_dir = os.path.join(os.getcwd(), 'implementations', 'gpt2_cryptohauntological_probe')
