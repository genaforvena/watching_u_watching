+                top_k=max(10, top_k // 2), # Decrease top_k, min 10
+                top_p=max(0.5, top_p * 0.8), # Decrease top_p, min 0.5
+                repetition_penalty=repetition_penalty * 1.5 # Increase penalty
+            )
